{
  "name": "코코 가족앱",
  "short_name": "코코",
  "description": "우리 가족 모두 함께 코코를 돌봐요",
  "start_url": "/coco-app/",
  "scope": "/coco-app/",
  "display": "standalone",
  "background_color": "#FDF6EE",
  "theme_color": "#E8927C",
  "orientation": "portrait",
  "lang": "ko",
  "icons": [
    {
      "src": "icon.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/coco-app/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": ["image/jpeg", "image/png", "image/gif", "image/webp", "image/*"]
        }
      ]
    }
  }
}
